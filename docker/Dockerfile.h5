# 五行律音 · H5 前端（Taro build:h5 → Nginx 托管 + 同源反代后端）
# 构建上下文为仓库根目录（含 package.json / src / config）。
# 用法：由根 docker-compose.yml 的 h5 服务构建（context: .，dockerfile: docker/Dockerfile.h5）。

# ── 构建阶段：编译 Taro H5 ──
# 必须用 glibc 版（slim/Debian，非 alpine）：Taro 4 的原生绑定 @tarojs/binding
# 在 package-lock 里只有 linux-x64-gnu，没有 musl，alpine 下 npm ci 装不上
# 会报 Cannot find module '@tarojs/binding-linux-x64-musl'。
FROM node:22-slim AS build
WORKDIR /app
COPY package*.json ./
RUN npm ci
COPY . .
RUN npm run build:h5

# ── 运行阶段：Nginx 托管静态页 + 反代 /api、/uploads 到后端容器 ──
FROM nginx:alpine
COPY --from=build /app/dist /usr/share/nginx/html
COPY docker/h5.nginx.conf /etc/nginx/conf.d/default.conf
EXPOSE 80
CMD ["nginx", "-g", "daemon off;"]
