# 复制为 .env 并按需修改。docker compose 会自动读取同目录 .env。

# ── 数据库 ──
# 默认 SQLite（容器内持久化到 db_data 卷）
DATABASE_URL=sqlite:////data/wuxing.db
# 用 MySQL 时改为（需 --profile mysql 启动 db 服务）：
# DATABASE_URL=mysql+pymysql://wuxing:wuxingpass@db:3306/wuxing?charset=utf8mb4

# ── 安全 ──
JWT_SECRET=请改成随机长字符串
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成强密码

# ── CORS（后台前端地址，JSON 数组）──
CORS_ORIGINS=["http://localhost:5173","http://127.0.0.1:5173"]

# ── MySQL（仅启用 mysql profile 时需要）──
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_DATABASE=wuxing
MYSQL_USER=wuxing
MYSQL_PASSWORD=wuxingpass
