# 复制为 .env 并填入真实值。docker compose 会自动读取同目录 .env。
# 完整部署与域名配置见 docs/DEPLOY.md。

# ── 运行模式 ──
# 生产必须 false：未配真实密钥（短信/支付/公众号）时后端「拒绝」而非「放行」。
# 开发/联调用 true：保留 dev 兜底（短信回传明文码、支付未配即免付开通、游客登录）。
DEBUG=false

# ── 外部 MySQL ──
# host.docker.internal = 宿主机（MySQL 装在跑 Docker 的同一台机器上时用）
# 1Panel 场景：换成 MySQL 的容器名（api 已接入 1panel-network）
DATABASE_URL=mysql+pymysql://用户名:密码@host.docker.internal:3306/wuxing?charset=utf8mb4
# 本地开发想用 SQLite 时改为：
# DATABASE_URL=sqlite:///./wuxing.db

# ── 安全 ──
# 必改！随机长串（如 openssl rand -hex 32）；DEBUG=false 时若仍为默认值后端拒绝启动
JWT_SECRET=请改成随机长字符串
ADMIN_USERNAME=admin
ADMIN_PASSWORD=请改成强密码

# ── CORS（允许跨域访问后端的前端地址，JSON 数组）──
# 必须包含：管理后台域名 +（若 H5 与后端不同源）H5 域名。同域反代则可省。
CORS_ORIGINS=["https://admin.your-domain.com","https://h5.your-domain.com"]
